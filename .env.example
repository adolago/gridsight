# Postgres
POSTGRES_DB=gridsight
POSTGRES_USER=gridsight
POSTGRES_PASSWORD=gridsight
POSTGRES_PORT=5432

# API
GRIDSIGHT_API_PORT=8000
GRIDSIGHT_DATA_DIR=./data

# App settings
GRIDSIGHT_DATABASE_URL=postgresql+psycopg://gridsight:gridsight@postgres:5432/gridsight
GRIDSIGHT_QDRANT_URL=http://qdrant:6333
GRIDSIGHT_QDRANT_COLLECTION=plays
# Optional for Qdrant Cloud
# GRIDSIGHT_QDRANT_API_KEY=your_key
